# ── Backend Server ───────────────────────────────────
PORT=3001
CORS_ORIGIN=*

# ── Monad Blockchain ────────────────────────────────
# Local Hardhat: http://127.0.0.1:8545
# Monad Testnet: https://testnet-rpc.monad.xyz/
MONAD_RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Price Conversion ─────────────────────────────────
# Fixed rate for MVP (1 USDC = 83 INR)
INR_TO_USDC_RATE=83

# ── Razorpay Payment Gateway ────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Leave empty to run in SIMULATE mode (no real payments)
# Fill in to enable REAL Razorpay payments (UPI, Card, NetBanking)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
