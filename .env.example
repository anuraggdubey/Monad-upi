# ── Monad Testnet ────────────────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
MONAD_CHAIN_ID=10143
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Deployed Contract Addresses ──────────────────────
# These will be filled after running `npx hardhat run scripts/deploy.js`
ESCROW_CONTRACT=0x...
IDENTITY_REGISTRY=0x...
REPUTATION_REGISTRY=0x...
X402_HANDLER=0x...
USDC_CONTRACT=0x...

# ── Backend Server ───────────────────────────────────
PORT=3001
JWT_SECRET=payagent-mvp-secret-change-in-production
CORS_ORIGIN=http://localhost:5173

# ── UPI / Razorpay (Mock for MVP) ────────────────────
# Leave empty for MVP — UPI payments are simulated
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Price Conversion ─────────────────────────────────
# Fixed rate for MVP (1 USDC = 83 INR)
INR_TO_USDC_RATE=83
